# Private per-DTF integration settings mounted as /config/project.env.
# Copy outside Git, one file per DTF/runtime. Do not put raw private keys here;
# signer material is mounted separately as a Foundry keystore.

# Required for proposer and defender. Choose the DTF/Folio this runtime operates.
# May also be supplied as container env.
FOLIO_ADDRESS=

# Optional defender override. If blank, defender resolves trading governance from the DTF.
GOVERNOR_ADDRESS=

# Optional overview/link settings used by proposer notifications/artifacts.
REGISTER_BASE_URL=
REGISTER_ORIGIN_URL=
CHAIN_LABEL=

# Optional proposer cadence. This targets auction starts at least this far apart.
REBALANCE_CADENCE=30d

# Required for live deployments unless ALLOW_PUBLIC_RPC=1.
# Prefer a project-scoped paid/private RPC for live broadcasts.
RPC_URL=
MAINNET_RPC_URL=
BSC_RPC_URL=
BASE_RPC_URL=

# Required for all proposer/defender market data. This is sent as the
# x-api-key header to the Scout ETL Read API.
SCOUT_ETL_API_KEY=***
SCOUT_ETL_BASE_URL=https://scout-etl.reserve-337.workers.dev
SCOUT_ETL_PROVIDER=messari
ALLOW_SYNTHETIC_SIGNAL_STRATEGY=0

# Required in live proposer mode when REQUIRE_SLACK=1.
# Optional for defender unless REQUIRE_SLACK=1.
SLACK_HOME_CHANNEL=
SLACK_BOT_TOKEN=***

# Optional defender email notifications. Private GitHub fork workflows use these
# through GitHub Secrets rather than this file.
DEFENDER_EMAIL_TO=
DEFENDER_EMAIL_FROM=
RESEND_API_KEY=***

# Defender AI approval uses Codex OAuth, not API keys. Live Defender requires
# REQUIRE_AI_APPROVAL=1 so non-veto proposals cannot pass without Codex approval.
# For Docker runs, set CODEX_AUTH_DIR_HOST in compose.env so auth.json is
# mounted at CODEX_HOME=/runtime/codex in proposer/defender containers.
REQUIRE_AI_APPROVAL=0

# Generated public signer metadata. The init command fills these values.
FOUNDRY_ACCOUNT=
SIGNER_ADDRESS=
# Optional. Set only when this runtime should open auctions and run CowBot.
AUCTION_LAUNCHER_ADDRESS=
AUCTION_LAUNCHER_FOUNDRY_ACCOUNT=
