# Non-secret Docker Compose substitution values. Keep a per-DTF copy outside Git
# when using the local Docker runner.
#
# Keep secrets in /srv/YOUR_DTF_SLUG/config/project.env and Foundry keystores, not here.

# Published runtime image. Pin to a sha-* or v* tag for repeatable runs.
DTF_OPERATOR_IMAGE=ghcr.io/reserve-protocol/dtf-operator:main

# Host UID/GID used by containers to avoid root-owned runtime files.
DTF_OPERATOR_UID=
DTF_OPERATOR_GID=

# Shared runtime paths. Replace YOUR_DTF_SLUG with a local name for this DTF.
DTF_RUNTIME_DIR=/srv/YOUR_DTF_SLUG
DTF_RUNTIME_DIR_HOST=/srv/YOUR_DTF_SLUG
PROJECT_ENV_FILE_HOST=/srv/YOUR_DTF_SLUG/config/project.env
FOUNDRY_KEYSTORE_DIR_HOST=/srv/YOUR_DTF_SLUG/foundry-keystores
FOUNDRY_KEYSTORE_PASSWORD_FILE_NAME=.dtf-operator.password
# Optional when the auction launcher uses a different Foundry password file.
AUCTION_LAUNCHER_KEYSTORE_PASSWORD_FILE_NAME=.dtf-operator.password
CODEX_AUTH_DIR_HOST=/srv/YOUR_DTF_SLUG/codex
RESTART_POLICY=unless-stopped
# Required. Set this to the chain for the DTF/Folio in project.env.
# Supported: 1 (Ethereum), 56 (BNB Smart Chain), 8453 (Base).
CHAIN_ID=
RPC_URL=
MAINNET_RPC_URL=
BSC_RPC_URL=
BASE_RPC_URL=

# Put SCOUT_ETL_API_KEY in PROJECT_ENV_FILE_HOST, not this non-secret compose file.
SCOUT_ETL_BASE_URL=https://scout-etl.reserve-337.workers.dev
SCOUT_ETL_PROVIDER=messari
ALLOW_SYNTHETIC_SIGNAL_STRATEGY=0

# Proposer service
PROPOSER_DATA_DIR=/srv/YOUR_DTF_SLUG/proposer-data
RUN_HOURS=4
POLL_SECONDS=20
COWBOT_SECONDS=30
REBALANCE_CADENCE=30d
# Optional proposer/open-auction scan tuning for providers with small eth_getLogs limits.
AUTO_REBALANCE_PROPOSAL_LOG_CHUNK_BLOCKS=
AUTO_REBALANCE_PROPOSAL_LOG_CHUNK_DELAY_MS=

# Defender service
DEFENDER_DATA_DIR=/srv/YOUR_DTF_SLUG/defender-data
WAIT_ACTIVE_SECONDS=120
DEFENDER_FREQUENCY_MINUTES=
# Optional RPC scan tuning for providers with small eth_getLogs limits.
DEFENDER_PROPOSAL_LOG_CHUNK_BLOCKS=
DEFENDER_PROPOSAL_LOG_CHUNK_DELAY_MS=
# Live Defender requires REQUIRE_AI_APPROVAL=1. Dry-run can leave this off.
REQUIRE_AI_APPROVAL=0
ALERT_ONLY_WITHOUT_SIGNER=1

# Runtime mode switches. Leave safe defaults unless intentionally arming live behavior.
ONCE=0
LIVE=0
ALLOW_BROADCAST=0
VETO_BROADCAST=0
# Slack is optional. Set to 1 only when SLACK_HOME_CHANNEL/SLACK_BOT_TOKEN are configured.
REQUIRE_SLACK=0
