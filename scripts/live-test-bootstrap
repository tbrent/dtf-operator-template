#!/usr/bin/env bash
set -euo pipefail

required=(
  DTF_OPERATOR_IMAGE CLI_PROXY_IMAGE BASE_RPC_URL
  DEFENDER_KEYSTORE_JSON_B64 DEFENDER_KEYSTORE_PASSWORD DEFENDER_FOUNDRY_ACCOUNT
  PROPOSER_SIGNER_ADDRESS CLIPROXY_AUTH_TGZ_B64
  CPA_PROPOSER_GITSTORE_URL CPA_PROPOSER_GITSTORE_BRANCH CPA_PROPOSER_GITSTORE_TOKEN
  CPA_DEFENDER_GITSTORE_URL CPA_DEFENDER_GITSTORE_BRANCH CPA_DEFENDER_GITSTORE_TOKEN
  OPERATOR_STATE_GIT_URL OPERATOR_STATE_GIT_BRANCH OPERATOR_STATE_GIT_TOKEN
)
for name in "${required[@]}"; do
  [[ -n "${!name:-}" ]] || { echo "error: $name is required" >&2; exit 2; }
done
[[ "$PROPOSER_SIGNER_ADDRESS" =~ ^0x[0-9a-fA-F]{40}$ ]] || { echo 'error: PROPOSER_SIGNER_ADDRESS must be an EVM address' >&2; exit 2; }
FUND_PROPOSER_WEI="${FUND_PROPOSER_WEI:-0}"
[[ "$FUND_PROPOSER_WEI" =~ ^[0-9]+$ ]] || { echo 'error: FUND_PROPOSER_WEI must be a non-negative integer' >&2; exit 2; }

umask 077
work="$(mktemp -d "${RUNNER_TEMP:-/tmp}/dtf-live-bootstrap.XXXXXX")"
cleanup() { rm -rf "$work"; }
trap cleanup EXIT

mkdir -m 700 "$work/runtime" "$work/cliproxy-auth" "$work/cliproxy-second-auth" "$work/proposer-auth" "$work/defender-auth" "$work/defender-data"
printf '%s' "$DEFENDER_KEYSTORE_JSON_B64" | base64 --decode > "$work/runtime/$DEFENDER_FOUNDRY_ACCOUNT"
printf '%s' "$DEFENDER_KEYSTORE_PASSWORD" > "$work/runtime/password"
chmod 600 "$work/runtime/$DEFENDER_FOUNDRY_ACCOUNT" "$work/runtime/password"

defender_signer="$(docker run --rm -v "$work/runtime:/runtime:ro" "$DTF_OPERATOR_IMAGE" cast wallet address --keystore "/runtime/$DEFENDER_FOUNDRY_ACCOUNT" --password-file /runtime/password)"
defender_balance="$(docker run --rm -e BASE_RPC_URL "$DTF_OPERATOR_IMAGE" sh -c 'cast balance "$1" --rpc-url "$BASE_RPC_URL"' sh "$defender_signer")"
proposer_balance="$(docker run --rm -e BASE_RPC_URL "$DTF_OPERATOR_IMAGE" sh -c 'cast balance "$1" --rpc-url "$BASE_RPC_URL"' sh "$PROPOSER_SIGNER_ADDRESS")"
echo "defender_signer=$defender_signer"
echo "defender_balance_wei=$defender_balance"
echo "proposer_signer=$PROPOSER_SIGNER_ADDRESS"
echo "proposer_balance_wei=$proposer_balance"
if (( FUND_PROPOSER_WEI > 0 && proposer_balance < FUND_PROPOSER_WEI )); then
  docker run --rm \
    -e BASE_RPC_URL \
    -v "$work/runtime:/runtime:ro" \
    "$DTF_OPERATOR_IMAGE" \
    cast send "$PROPOSER_SIGNER_ADDRESS" \
      --value "$FUND_PROPOSER_WEI" \
      --keystore "/runtime/$DEFENDER_FOUNDRY_ACCOUNT" \
      --password-file /runtime/password \
      --rpc-url "$BASE_RPC_URL" \
      --json
fi

printf '%s' "$CLIPROXY_AUTH_TGZ_B64" | base64 --decode | tar --no-same-owner -xzf - -C "$work/cliproxy-auth"
mapfile -d '' auth_files < <(find "$work/cliproxy-auth" -type f -name '*.json' -print0 | sort -z)
echo "primary_oauth_record_count=${#auth_files[@]}"
(( ${#auth_files[@]} >= 1 )) || { echo 'error: primary CPA OAuth archive contains no records' >&2; exit 2; }
proposer_auth="${auth_files[0]}"
if [[ -n "${CLIPROXY_SECOND_AUTH_TGZ_B64:-}" ]]; then
  printf '%s' "$CLIPROXY_SECOND_AUTH_TGZ_B64" | base64 --decode | tar --no-same-owner -xzf - -C "$work/cliproxy-second-auth"
  mapfile -d '' second_auth_files < <(find "$work/cliproxy-second-auth" -type f -name '*.json' -print0 | sort -z)
  echo "secondary_oauth_record_count=${#second_auth_files[@]}"
  (( ${#second_auth_files[@]} >= 1 )) || { echo 'error: secondary CPA OAuth archive contains no records' >&2; exit 2; }
  defender_auth="${second_auth_files[0]}"
else
  (( ${#auth_files[@]} >= 2 )) || { echo 'error: a second independent CPA OAuth archive is required' >&2; exit 2; }
  defender_auth="${auth_files[1]}"
fi
proposer_identity="$(jq -r '.account_id // .email // empty' "$proposer_auth")"
defender_identity="$(jq -r '.account_id // .email // empty' "$defender_auth")"
[[ -n "$proposer_identity" && -n "$defender_identity" ]] || { echo 'error: CPA OAuth records lack account identity fields' >&2; exit 2; }
[[ "$proposer_identity" != "$defender_identity" ]] || { echo 'error: Proposer and Defender CPA OAuth records resolve to the same account' >&2; exit 2; }
cp "$proposer_auth" "$work/proposer-auth/$(basename "$proposer_auth")"
cp "$defender_auth" "$work/defender-auth/$(basename "$defender_auth")"

export GITSTORE_GIT_TOKEN="$CPA_PROPOSER_GITSTORE_TOKEN"
scripts/seed-cliproxy-gitstore \
  --git-url "$CPA_PROPOSER_GITSTORE_URL" \
  --git-branch "$CPA_PROPOSER_GITSTORE_BRANCH" \
  --git-username "${CPA_GITSTORE_GIT_USERNAME:-x-access-token}" \
  --cliproxy-auth-dir "$work/proposer-auth" \
  --cliproxy-image "$CLI_PROXY_IMAGE"
export GITSTORE_GIT_TOKEN="$CPA_DEFENDER_GITSTORE_TOKEN"
scripts/seed-cliproxy-gitstore \
  --git-url "$CPA_DEFENDER_GITSTORE_URL" \
  --git-branch "$CPA_DEFENDER_GITSTORE_BRANCH" \
  --git-username "${CPA_GITSTORE_GIT_USERNAME:-x-access-token}" \
  --cliproxy-auth-dir "$work/defender-auth" \
  --cliproxy-image "$CLI_PROXY_IMAGE"
unset GITSTORE_GIT_TOKEN

export OPERATOR_STATE_MODE=git-authoritative
operator_state() {
  docker run --rm \
    -e OPERATOR_STATE_GIT_URL \
    -e OPERATOR_STATE_GIT_BRANCH \
    -e OPERATOR_STATE_GIT_TOKEN \
    -e OPERATOR_STATE_MODE \
    -v "$work/defender-data:/data" \
    "$DTF_OPERATOR_IMAGE" \
    node dist/cli/run-defender-state.js "$@" --state-root /data
}
if operator_state restore; then
  operator_state validate
  operator_state status
else
  rm -rf "$work/defender-data"
  mkdir -m 700 "$work/defender-data"
  operator_state seed
  operator_state validate
  operator_state cutover
  rm -rf "$work/defender-data"
  mkdir -m 700 "$work/defender-data"
  operator_state restore
  operator_state validate
  operator_state status
fi
