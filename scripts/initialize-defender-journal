#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: CPA_DEFENDER_GITSTORE_TOKEN=<scoped-write-token> \
  scripts/initialize-defender-journal --git-branch <branch> \
  [--repo <owner/repo>]

Creates a fresh, empty authoritative Defender journal in an absent branch of
the private repository already configured by CPA_DEFENDER_GITSTORE_URL, verifies
a clean restore, and configures OPERATOR_STATE_GIT_BRANCH. It reuses the scoped
CPA_DEFENDER_GITSTORE_TOKEN without printing it or creating a duplicate Secret.
It does not import prior runtime files and refuses an existing branch. The
helper never deletes or force-pushes a private persistence branch.
EOF
}

die() {
  echo "error: $*" >&2
  exit 2
}

set_variable() {
  local name="$1"
  local value="$2"
  if [[ -n "$repo" ]]; then
    gh variable set "$name" --repo "$repo" --body "$value"
  else
    gh variable set "$name" --body "$value"
  fi
}

get_variable() {
  local name="$1"
  if [[ -n "$repo" ]]; then
    gh variable get "$name" --repo "$repo" 2>/dev/null || true
  else
    gh variable get "$name" 2>/dev/null || true
  fi
}

git_branch=""
repo=""
operator_image="ghcr.io/reserve-protocol/dtf-operator@sha256:154b3e62e5ff99fe33961cbba64c7aa83bee129fafe81fe500d6cbb0594db61c"
operator_revision="4f7cff1648552c679ee5b22bb5a35fbcb26cc5f1"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --git-branch) git_branch="${2:-}"; shift 2 ;;
    --repo) repo="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) die "unknown argument: $1" ;;
  esac
done

[[ -n "$git_branch" ]] || die "--git-branch is required"
[[ "$git_branch" =~ ^[A-Za-z0-9][A-Za-z0-9._/-]*$ && "$git_branch" != *..* && "$git_branch" != */ && "$git_branch" != *//* ]] || die "--git-branch is not a safe branch name"
[[ -n "${CPA_DEFENDER_GITSTORE_TOKEN:-}" ]] || die "CPA_DEFENDER_GITSTORE_TOKEN is required"
command -v docker >/dev/null 2>&1 || die "docker is required"
command -v gh >/dev/null 2>&1 || die "gh is required"

git_url="$(get_variable CPA_DEFENDER_GITSTORE_URL)"
cpa_branch="$(get_variable CPA_DEFENDER_GITSTORE_BRANCH)"
[[ -n "$git_url" ]] || die "CPA_DEFENDER_GITSTORE_URL must be configured before journal initialization"
[[ -n "$cpa_branch" ]] || die "CPA_DEFENDER_GITSTORE_BRANCH must be configured before journal initialization"
case "$git_url" in
  http://*@*|https://*@*) die "CPA_DEFENDER_GITSTORE_URL must not contain credentials" ;;
esac
[[ "$git_branch" != "$cpa_branch" ]] || die "Defender CPA and journal branches must differ"
proposer_url="$(get_variable CPA_PROPOSER_GITSTORE_URL)"
normalized_defender_url="${git_url,,}"
normalized_defender_url="${normalized_defender_url%/}"
normalized_defender_url="${normalized_defender_url%.git}"
normalized_proposer_url="${proposer_url,,}"
normalized_proposer_url="${normalized_proposer_url%/}"
normalized_proposer_url="${normalized_proposer_url%.git}"
if [[ -n "$normalized_proposer_url" && "$normalized_defender_url" == "$normalized_proposer_url" ]]; then
  die "Proposer and Defender CPA GitStores must use different repositories"
fi

docker pull --platform linux/amd64 "$operator_image"
platform="$(docker image inspect "$operator_image" --format '{{.Os}}/{{.Architecture}}')"
revision="$(docker image inspect "$operator_image" --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}')"
[[ "$platform" == linux/amd64 ]] || die "operator image must be linux/amd64"
[[ "$revision" == "$operator_revision" ]] || die "operator OCI revision does not match the reviewed source revision"

umask 077
state_dir="$(mktemp -d "${TMPDIR:-/tmp}/defender-journal-init.XXXXXX")"
verify_dir="$(mktemp -d "${TMPDIR:-/tmp}/defender-journal-verify.XXXXXX")"
initialized=0
cleanup() {
  status=$?
  trap - EXIT
  for dir in "$state_dir" "$verify_dir"; do
    docker run --rm --platform linux/amd64 --entrypoint sh -v "$dir:/data" "$operator_image" \
      -c 'chmod -R a+rwX /data' >/dev/null 2>&1 || true
    rm -rf "$dir" >/dev/null 2>&1 || true
  done
  if [[ "$status" != 0 && "$initialized" == 1 ]]; then
    echo "error: journal initialization did not complete; the private branch may contain an initial generation that was not restore-verified and was intentionally left intact" >&2
  fi
  exit "$status"
}
trap cleanup EXIT

common_args=(
  --rm
  --platform linux/amd64
  -e OPERATOR_STATE_GIT_URL="$git_url"
  -e OPERATOR_STATE_GIT_BRANCH="$git_branch"
  -e OPERATOR_STATE_GIT_TOKEN
  -e OPERATOR_STATE_MODE=git-authoritative
  -e OPERATOR_STATE_ROOT=/data
  -v "$state_dir:/data"
  "$operator_image"
  node dist/cli/run-defender-state.js
)

OPERATOR_STATE_GIT_TOKEN="$CPA_DEFENDER_GITSTORE_TOKEN" docker run "${common_args[@]}" initialize
initialized=1

verify_args=(
  --rm
  --platform linux/amd64
  -e OPERATOR_STATE_GIT_URL="$git_url"
  -e OPERATOR_STATE_GIT_BRANCH="$git_branch"
  -e OPERATOR_STATE_GIT_TOKEN
  -e OPERATOR_STATE_MODE=git-authoritative
  -e OPERATOR_STATE_ROOT=/data
  -v "$verify_dir:/data"
  "$operator_image"
  node dist/cli/run-defender-state.js
)

OPERATOR_STATE_GIT_TOKEN="$CPA_DEFENDER_GITSTORE_TOKEN" docker run "${verify_args[@]}" restore
OPERATOR_STATE_GIT_TOKEN="$CPA_DEFENDER_GITSTORE_TOKEN" docker run "${verify_args[@]}" validate

set_variable OPERATOR_STATE_GIT_BRANCH "$git_branch"

echo "defender_repository_reused=1"
echo "defender_journal_initialized=1"
echo "defender_journal_restore_verified=1"
echo "operator_source_revision=$operator_revision"
echo "next_step=protect both Defender branches against force-pushes and deletion before production dispatch"
